# Local face-detection sandbox: keep the Swift script in source, but never
# commit real-person test photos the user drops into tool/face_test/.
tool/face_test/*.jpg
tool/face_test/*.png

# Generated App Store preview videos — 3GB of build artifacts from the
# preview pipeline (record → finalize). The tools live in tool/ but the
# outputs are device-rendered and not source.
aso/previews/

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Generated native splash artifacts. flutter_native_splash regenerates these
# per-sport on every `tool/build_sport.sh <sport>` run, so tracking them just
# churns the diff and risks committing one sport's splash as another's. The
# real sources live in assets/icon/*_splash.png. After a fresh clone, run
# `tool/build_sport.sh <sport>` (or `dart run flutter_native_splash:create`)
# to regenerate them before building.
ios/Runner/Assets.xcassets/LaunchImage.imageset/LaunchImage*.png
android/app/src/main/res/drawable-*/splash.png
android/app/src/main/res/drawable-*/android12splash.png

# fastlane lane run output (transient test report)
tool/app_privacy/fastlane/report.xml
